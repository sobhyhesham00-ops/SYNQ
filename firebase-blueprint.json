{
  "entities": {
    "user": {
      "title": "User",
      "description": "User profile containing name, role, email, status, avatar",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "email": { "type": "string" },
        "status": { "type": "string" },
        "avatarUrl": { "type": "string" }
      }
    },
    "todo": {
      "title": "Todo",
      "description": "Agent to-dos containing category and description",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agentName": { "type": "string" },
        "text": { "type": "string" },
        "isCompleted": { "type": "boolean" },
        "reminderTimeMs": { "type": "number" },
        "createdAt": { "type": "string" },
        "category": { "type": "string" }
      }
    },
    "inquiry": {
      "title": "Inquiry",
      "description": "Customer inquiry submitted by agent",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agentName": { "type": "string" },
        "clinicName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "qa_score": {
      "title": "QAScore",
      "description": "Quality assurance evaluation record and scores",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "qaName": { "type": "string" },
        "agentName": { "type": "string" },
        "totalScore": { "type": "number" }
      }
    },
    "tt_request": {
      "title": "TabbyTamaraRequest",
      "description": "Payment requests via Tabby/Tamara finance portals",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agentName": { "type": "string" },
        "patientName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "status": { "type": "string" },
        "agentFollowUps": { "type": "array" }
      }
    },
    "tt_complaint": {
      "title": "TabbyTamaraComplaint",
      "description": "Customer complaints received regarding financial portals",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agentName": { "type": "string" },
        "patientName": { "type": "string" },
        "status": { "type": "string" },
        "tlResolutionType": { "type": "string" }
      }
    },
    "client_comm": {
      "title": "ClientCommunicationRequest",
      "description": "Outgoing patient contact requests",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "callCenterAgentName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "scheduling_request": {
      "title": "SchedulingRequest",
      "description": "Annual leaves or shift swaps submitted by agents",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agentName": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "timelog": {
      "title": "TimeLog",
      "description": "Daily attendance and break time trackers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agentName": { "type": "string" },
        "clockIn": { "type": "string" }
      }
    },
    "announcement": {
      "title": "Announcement",
      "description": "Global notification bulletins published by TLs",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "case": {
      "title": "CaseRecord",
      "description": "Helpdesk clinical ticket records",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agentName": { "type": "string" },
        "patientName": { "type": "string" }
      }
    },
    "tl_feedback": {
      "title": "TLFeedback",
      "description": "Weekly performance feedback sheets",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agentName": { "type": "string" },
        "tlName": { "type": "string" }
      }
    },
    "message": {
      "title": "ChatMessage",
      "description": "Chat messages sent between agents, channels, or TLs",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderName": { "type": "string" },
        "senderId": { "type": "string" },
        "receiverName": { "type": "string" },
        "text": { "type": "string" },
        "attachment": { "type": "string" },
        "attachmentName": { "type": "string" },
        "createdAt": { "type": "string" },
        "seen": { "type": "boolean" },
        "language": { "type": "string" }
      }
    },
    "article": {
      "title": "Article",
      "description": "Educational or dynamic clinic articles managed by management users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string" },
        "createdBy": { "type": "string" }
      }
    },
    "tl_shift_log": {
      "title": "TLShiftLog",
      "description": "Shift logs recorded once daily when a Team Leader logs into the app",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tlName": { "type": "string" },
        "shift": { "type": "string" },
        "loggedInAt": { "type": "string" },
        "date": { "type": "string" }
      }
    },
    "admin_audit_log": {
      "title": "AdminAuditLog",
      "description": "Log of admin actions performed by directors or super admins",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "action": { "type": "string" },
        "targetUser": { "type": "string" },
        "performedBy": { "type": "string" },
        "timestamp": { "type": "string" }
      }
    }
  },
  "firestore": {
    "admin_audit_log/{logId}": {
      "schema": { "$ref": "#/entities/admin_audit_log" },
      "description": "Audit logs of actions taken by super admins or directors"
    },
    "users/{userId}": {
      "schema": { "$ref": "#/entities/user" },
      "description": "User profiles"
    },
    "tl_shift_logs/{logId}": {
      "schema": { "$ref": "#/entities/tl_shift_log" },
      "description": "Daily logged shifts for Team Leaders"
    },
    "todos/{todoId}": {
      "schema": { "$ref": "#/entities/todo" },
      "description": "Agent reminders and simple scratch todo pads"
    },
    "inquiries/{inquiryId}": {
      "schema": { "$ref": "#/entities/inquiry" },
      "description": "Customer inquiry records"
    },
    "qa_scores/{scoreId}": {
      "schema": { "$ref": "#/entities/qa_score" },
      "description": "Quality scoring parameters"
    },
    "tt_requests/{reqId}": {
      "schema": { "$ref": "#/entities/tt_request" },
      "description": "Tabby and Tamara approval requests"
    },
    "tt_complaints/{compId}": {
      "schema": { "$ref": "#/entities/tt_complaint" },
      "description": "Tabby and Tamara customer complaints"
    },
    "client_comms/{commId}": {
      "schema": { "$ref": "#/entities/client_comm" },
      "description": "Custom communication requests and patient updates"
    },
    "scheduling_requests/{reqId}": {
      "schema": { "$ref": "#/entities/scheduling_request" },
      "description": "Team scheduling and annual leaves"
    },
    "timelogs/{logId}": {
      "schema": { "$ref": "#/entities/timelog" },
      "description": "Team logs and attendance sheets"
    },
    "announcements/{annId}": {
      "schema": { "$ref": "#/entities/announcement" },
      "description": "System bulletins and announcements"
    },
    "cases/{caseId}": {
      "schema": { "$ref": "#/entities/case" },
      "description": "Clinic desk incidents"
    },
    "tl_feedbacks/{fbId}": {
      "schema": { "$ref": "#/entities/tl_feedback" },
      "description": "Team feedback sheets"
    },
    "messages/{msgId}": {
      "schema": { "$ref": "#/entities/message" },
      "description": "Real-time communication messages"
    },
    "articles/{articleId}": {
      "schema": { "$ref": "#/entities/article" },
      "description": "Stored clinic articles"
    }
  }
}
