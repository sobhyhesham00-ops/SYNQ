rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() { return request.auth != null; }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function getUserName() {
      let data = getUserData();
      return data != null ? data.name : null;
    }

    function getUserNameLower() {
      let name = getUserName();
      return name != null ? name.toLowerCase() : null;
    }

    function getUserRole() {
      let data = getUserData();
      return data != null ? data.role : null;
    }

    // Checking roles handles TL, Admin, and Superadmin roles securely
    function isSuperAdmin() {
      let role = getUserRole();
      return role == 'tl' || role == 'admin' || role == 'superadmin' || role == 'director';
    }

    function isTLOrSupport() {
      return getUserRole() == 'tl';
    }

    function isRecipientOf(notifData) {
      let uid = request.auth.uid;
      let role = getUserRole();
      let name = getUserName();
      let nameLower = getUserNameLower();
      return notifData.targetAgent == uid ||
             notifData.targetAgent == "all" ||
             (role != null && notifData.targetAgent == role) ||
             (notifData.targetGroups != null && (
               notifData.targetGroups.hasAny([uid, "usr_" + uid, "all"]) ||
               (role != null && role in notifData.targetGroups) ||
               (name != null && name in notifData.targetGroups) ||
               (nameLower != null && nameLower in notifData.targetGroups)
             ));
    }

    // Users
    // Gating read rules behind a simple "request.auth != null" check prevents the circular
    // evaluation loop that happens when a getUserRole() lookup triggers a read of its own users collection.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        isSuperAdmin() ||
        isTLOrSupport() ||
        request.auth.uid == userId || 
        (resource != null && request.auth.uid == resource.data.uid) || 
        (request.resource != null && request.auth.uid == request.resource.data.uid) || 
        (resource != null && getUserName() != null && getUserName() == resource.data.name) || 
        (request.resource != null && getUserName() != null && getUserName() == request.resource.data.name) || 
        !exists(/databases/$(database)/documents/users/$(request.auth.uid))
      );
    }

    // Cases, Requests, Inquiries
    match /inquiries/{docId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null && (
        isSuperAdmin() || 
        isTLOrSupport() || 
        (resource != null && resource.data.agentName == getUserName()) || 
        (request.resource != null && request.resource.data.agentName == getUserName())
      );
      allow update: if request.auth != null && (
        isSuperAdmin() || 
        isTLOrSupport() || 
        (resource != null && resource.data.agentName == getUserName()) || 
        (request.resource != null && request.resource.data.agentName == getUserName()) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastHourlyReminderAt'])
      );
    }
    function canWriteFintech() {
      return request.auth != null && (
        isSuperAdmin() || 
        isTLOrSupport() || 
        getUserRole() == 'qa' || 
        (resource != null && resource.data.agentName == getUserName()) || 
        (request.resource != null && request.resource.data.agentName == getUserName())
      );
    }

    match /tt_requests/{docId} {
      allow read: if request.auth != null;
      allow write: if canWriteFintech();
    }
    match /tt_complaints/{docId} {
      allow read: if request.auth != null;
      allow write: if canWriteFintech();
    }
    // Explicitly add support for tabby_tamara and tabby_tamara_complaints aliases, which correctly use getUserRole()
    match /tabby_tamara/{docId} {
      allow read: if request.auth != null;
      allow write: if canWriteFintech();
    }
    match /tabby_tamara_complaints/{docId} {
      allow read: if request.auth != null;
      allow write: if canWriteFintech();
    }

    match /client_comms/{docId} {
      allow read, write: if isSignedIn();
    }
    match /scheduling_requests/{docId} {
      allow read, write: if isSignedIn();
    }
    match /cases/{docId} {
      allow read, write: if isSignedIn();
    }
    match /case_activity/{docId} {
      allow read, create: if isSignedIn();
      allow update, delete: if false;
    }

    // Timelogs
    match /timelogs/{logId} {
      allow read, write: if isSignedIn();
    }

    // TL Shift Logs
    match /tl_shift_logs/{logId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (isSuperAdmin() || isTLOrSupport()) && (
        (resource == null && request.resource.data.tlName == getUserName()) ||
        (resource != null && resource.data.tlName == getUserName() && request.resource.data.tlName == getUserName())
      );
    }

    // Notifications
    match /notifications/{notifId} {
      allow read, create: if isSignedIn();
      allow update: if isSignedIn() && (
        isSuperAdmin() || 
        isTLOrSupport() ||
        resource.data.targetAgent == getUserName() ||
        resource.data.targetAgent == "all" ||
        resource.data.targetAgent == getUserRole() ||
        (resource.data.targetGroups != null && getUserName() in resource.data.targetGroups) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['seenByUsers', 'clearedByUsers'])
      );
      allow delete: if isSignedIn() && (isSuperAdmin() || isTLOrSupport());
    }

    // Others (Basic fallback for existing functionality)
    match /todos/{todoId} { allow read, write: if isSignedIn(); }
    match /qa_scores/{scoreId} { allow read, write: if isSignedIn(); }
    match /system/sched_credentials {
      allow read, write: if request.auth != null;
    }
    match /system/sched_locked_accounts {
      allow read, write: if request.auth != null;
    }
    match /system/{docId} { allow read, write: if isSignedIn(); }
    match /system/sched_agent_directory {
      allow read: if request.auth != null || request.auth == null;  // allow all reads from cache
      allow write: if request.auth != null;  // require any auth (anon or real user)
    }
    match /system/sched_agent_directory_headers {
      allow read: if request.auth != null || request.auth == null;
      allow write: if request.auth != null;
    }
    match /announcements/{annId} { allow read, write: if isSignedIn(); }
    match /tl_feedbacks/{fbId} { allow read, write: if isSignedIn(); }
    match /schedules/{schedId} { allow read, write: if isSignedIn(); }
    match /attendance_records/{docId} { allow read, write: if isSignedIn(); }
    match /orders/{orderId} { allow read, write: if isSignedIn(); }
    match /agents/{agentId} { allow read, write: if isSignedIn(); }
    match /agents/{agentId}/schedules/{schedId} { allow read, write: if isSignedIn(); }

    // Messages
    match /messages/{msgId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow delete: if isSignedIn() && request.auth.uid in resource.data.participants;
    }

    // Articles
    match /articles/{articleId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && (
        isSuperAdmin() || isTLOrSupport() ||
        (request.auth.token.role == 'qa')
      );
    }
  }
}
