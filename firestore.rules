rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    function isSignedIn() { return request.auth != null; }
    match /users/{userId} { allow read, write: if isSignedIn(); }
    match /inquiries/{docId} { allow read, write: if isSignedIn(); }
    match /tt_requests/{docId} { allow read, write: if isSignedIn(); }
    match /tt_complaints/{docId} { allow read, write: if isSignedIn(); }
    match /client_comms/{docId} { allow read, write: if isSignedIn(); }
    match /scheduling_requests/{docId} { allow read, write: if isSignedIn(); }
    match /cases/{docId} { allow read, write: if isSignedIn(); }
    match /case_activity/{docId} { allow read, create: if isSignedIn(); allow update, delete: if false; }
    match /notifications/{notifId} { allow read, write: if isSignedIn(); }
    match /timelogs/{logId} { allow read, write: if isSignedIn(); }
    match /todos/{todoId} { allow read, write: if isSignedIn(); }
    match /qa_scores/{scoreId} { allow read, write: if isSignedIn(); }
    match /qa_config/{docId} { allow read, write: if isSignedIn(); }
    match /system/{docId} { allow read, write: if isSignedIn(); }
    match /announcements/{annId} { allow read, write: if isSignedIn(); }
    match /tl_feedbacks/{fbId} { allow read, write: if isSignedIn(); }
    match /schedules/{schedId} { allow read, write: if isSignedIn(); }
    match /orders/{orderId} { allow read, write: if isSignedIn(); }
    match /agents/{agentId} { allow read, write: if isSignedIn(); }
    match /agents/{agentId}/schedules/{schedId} { allow read, write: if isSignedIn(); }
    match /credentials/{docId} { allow read, write: if isSignedIn(); }
    match /meta/{docId} { allow read, write: if isSignedIn(); }
    match /directory/{docId} { allow read, write: if isSignedIn(); }
    match /roster_published/{docId} { allow read, write: if isSignedIn(); }
  }
}
