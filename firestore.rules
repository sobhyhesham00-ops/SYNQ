rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() { return request.auth != null; }

    function getUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data : null;
    }

    function getUserName() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name : null;
    }

    function getUserRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role : null;
    }

    // Checking roles handles TL, Admin, and Superadmin roles securely
    function isSuperAdmin() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'director' &&
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name == 'Hesham Sobhy' || 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username == 'h.sobhy');
    }

    // Directors other than h.sobhy have the same level of access as TLs. 
    function isTLOrSupport() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'tl' || (
                 get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'director' &&
                 !(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name == 'Hesham Sobhy' || 
                   get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username == 'h.sobhy')
               )
             );
    }

    function isRecipientOf(notifData) {
      return notifData.targetAgent == request.auth.uid ||
             notifData.targetAgent == "all" ||
             (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
                notifData.targetAgent == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role ||
                (notifData.targetGroups != null && (
                   notifData.targetGroups.hasAny([request.auth.uid, "usr_" + request.auth.uid, "all"]) ||
                   get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in notifData.targetGroups ||
                   get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name in notifData.targetGroups
                ))
             ));
    }

    function canWriteFintech() {
      return request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'director' && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name == 'Hesham Sobhy' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username == 'h.sobhy')) || 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'tl' || (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'director' && !(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name == 'Hesham Sobhy' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username == 'h.sobhy'))) || 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'qa') || 
        (resource != null && resource.data.agentName == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name) || 
        (request.resource != null && request.resource.data.agentName == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name)
      );
    }

    // Users
    // Gating read rules behind a simple "request.auth != null" check prevents the circular
    // evaluation loop that happens when a getUserRole() lookup triggers a read of its own users collection.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        request.auth.uid == userId || 
        getUserRole() == 'director' || 
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
        (getUserData() != null && getUserData().id == "usr_" + userId) ||
        (getUserName() != null && getUserName() == request.resource.data.name)
      );
    }

    // Cases, Requests, Inquiries
    match /inquiries/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        isSuperAdmin() || 
        isTLOrSupport() || 
        (resource != null && resource.data.agentName == getUserName()) || 
        (request.resource != null && request.resource.data.agentName == getUserName())
      );
    }

    match /tt_requests/{docId} {
      allow read: if request.auth != null;
      allow write: if canWriteFintech();
    }
    match /tt_complaints/{docId} {
      allow read: if request.auth != null;
      allow write: if canWriteFintech();
    }
    // Explicitly add support for tabby_tamara and tabby_tamara_complaints aliases, which correctly use getUserRole()
    match /tabby_tamara/{docId} {
      allow read: if request.auth != null;
      allow write: if canWriteFintech();
    }
    match /tabby_tamara_complaints/{docId} {
      allow read: if request.auth != null;
      allow write: if canWriteFintech();
    }

    match /client_comms/{docId} {
      allow read, write: if isSignedIn();
    }
    match /scheduling_requests/{docId} {
      allow read, write: if isSignedIn();
    }
    match /cases/{docId} {
      allow read, write: if isSignedIn();
    }
    match /case_activity/{docId} {
      allow read, create: if isSignedIn();
      allow update, delete: if false;
    }

    // Timelogs
    match /timelogs/{logId} {
      allow read, write: if isSignedIn();
    }

    // TL Shift Logs
    match /tl_shift_logs/{logId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (isSuperAdmin() || isTLOrSupport()) && (
        (resource == null && request.resource.data.tlName == getUserName()) ||
        (resource != null && resource.data.tlName == getUserName() && request.resource.data.tlName == getUserName())
      );
    }

    // TL Login Logs
    match /tl_login_logs/{logId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isSuperAdmin() || isTLOrSupport());
    }

    // Notifications
    match /notifications/{notifId} {
      allow read, create: if isSignedIn();
      allow update: if isSignedIn() && (
        isSuperAdmin() || 
        isTLOrSupport() ||
        resource.data.targetAgent == getUserName() ||
        resource.data.targetAgent == "all" ||
        resource.data.targetAgent == getUserRole() ||
        (resource.data.targetGroups != null && getUserName() in resource.data.targetGroups) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['seenByUsers', 'clearedByUsers'])
      );
      allow delete: if isSignedIn() && (isSuperAdmin() || isTLOrSupport());
    }

    // Others (Basic fallback for existing functionality)
    match /todos/{todoId} { allow read, write: if isSignedIn(); }
    match /qa_scores/{scoreId} { allow read, write: if isSignedIn(); }
    match /system/{docId} { allow read, write: if isSignedIn(); }
    match /system/sched_agent_directory {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    match /system/sched_agent_directory_headers {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    match /announcements/{annId} { allow read, write: if isSignedIn(); }
    match /tl_feedbacks/{fbId} { allow read, write: if isSignedIn(); }
    match /schedules/{schedId} { allow read, write: if isSignedIn(); }
    match /attendance_records/{docId} { allow read, write: if isSignedIn(); }
    match /orders/{orderId} { allow read, write: if isSignedIn(); }
    match /agents/{agentId} { allow read, write: if isSignedIn(); }
    match /agents/{agentId}/schedules/{schedId} { allow read, write: if isSignedIn(); }

    // Messages
    match /messages/{msgId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow delete: if isSignedIn() && request.auth.uid in resource.data.participants;
    }

    // Articles
    match /articles/{articleId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && (
        isSuperAdmin() || isTLOrSupport() ||
        (getUserRole() == 'qa')
      );
    }
  }
}
