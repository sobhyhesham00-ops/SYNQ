rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() { return request.auth != null; }

    // Checking roles handles TL, Admin, and Superadmin roles securely
    function isSuperAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name == 'Hesham Sobhy' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name == 'hesham sobhy' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username == 'h.sobhy' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username == 'H.Sobhy' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.id == 'usr_heshamsobhy'
        );
    }

    // Directors other than h.sobhy have the same level of access as TLs. 
    function isTLOrSupport() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'tl' || (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'director' &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name != 'Hesham Sobhy' &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username != 'h.sobhy'
          )
        );
    }

    function canWriteFintech() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'tl' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'director' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'qa' ||
          (resource != null && (
            resource.data.agentName == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name ||
            resource.data.submittedByName == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name ||
            resource.data.assignedToName == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name
          )) ||
          (request.resource != null && (
            request.resource.data.agentName == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name ||
            request.resource.data.submittedByName == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name ||
            request.resource.data.assignedToName == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name
          ))
        );
    }

    // Gating read rules behind a simple "request.auth != null" check prevents the circular
    // evaluation loop that happens when a getUserRole() lookup triggers a read of its own users collection.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        request.auth.uid == userId || 
        isSuperAdmin() ||
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.id == "usr_" + userId) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name == request.resource.data.name)
      );
    }

    // Cases, Requests, Inquiries
    match /inquiries/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        isSuperAdmin() ||
        isTLOrSupport() ||
        (resource != null && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name == resource.data.agentName ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name == resource.data.assignedToName
        )) ||
        (request.resource != null && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name == request.resource.data.agentName ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name == request.resource.data.assignedToName
        ))
      );
    }

    match /tt_requests/{docId} {
      allow read: if request.auth != null;
      allow write: if canWriteFintech();
    }
    match /tt_complaints/{docId} {
      allow read: if request.auth != null;
      allow write: if canWriteFintech();
    }


    match /client_comms/{docId} {
      allow read, write: if isSignedIn();
    }
    match /scheduling_requests/{docId} {
      allow read, write: if isSignedIn();
    }
    match /cases/{docId} {
      allow read, write: if isSignedIn();
    }
    match /case_activity/{docId} {
      allow read, create: if isSignedIn();
      allow update, delete: if false;
    }

    // Timelogs
    match /timelogs/{logId} {
      allow read, write: if isSignedIn();
    }

    // TL Shift Logs
    match /tl_shift_logs/{logId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (isSuperAdmin() || isTLOrSupport()) && (
        (resource == null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name == request.resource.data.tlName) ||
        (resource != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name == resource.data.tlName && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name == request.resource.data.tlName)
      );
    }

    // TL Login Logs
    match /tl_login_logs/{logId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Notifications
    match /notifications/{notifId} {
      allow read, create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && (isSuperAdmin() || isTLOrSupport());
    }

    // Others (Basic fallback for existing functionality)
    match /todos/{todoId} { allow read, write: if isSignedIn(); }
    match /filter_presets/{presetId} {
      allow read, write: if isSignedIn() && (
        resource == null ||
        resource.data.userId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name == resource.data.userId ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && resource.data.userId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.id) ||
        isSuperAdmin()
      );
      allow create: if isSignedIn();
    }
    match /qa_scores/{scoreId} { allow read, write: if isSignedIn(); }
    match /system/{docId} { allow read, write: if isSignedIn(); }
    match /system/sched_agent_directory {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    match /system/sched_agent_directory_headers {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    match /announcements/{annId} { allow read, write: if isSignedIn(); }
    match /tl_feedbacks/{fbId} { allow read, write: if isSignedIn(); }
    match /schedules/{schedId} { allow read, write: if isSignedIn(); }
    match /attendance_records/{docId} { allow read, write: if isSignedIn(); }
    match /orders/{orderId} { allow read, write: if isSignedIn(); }
    match /agents/{agentId} { allow read, write: if isSignedIn(); }
    match /agents/{agentId}/schedules/{schedId} { allow read, write: if isSignedIn(); }

    // Messages
    match /messages/{msgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && (isSuperAdmin() || isTLOrSupport());
    }

    // Articles
    match /articles/{articleId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && (
        isSuperAdmin() || isTLOrSupport() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'qa')
      );
    }

    // Admin Audit Log
    match /admin_audit_log/{logId} {
      allow read: if isSignedIn() && isSuperAdmin();
      allow create: if isSignedIn() && isSuperAdmin();
      allow update, delete: if false;
    }
  }
}
