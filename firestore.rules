rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    
    // Note: If Firebase Auth custom claims are not set, we look up the user document.
    // This costs 1 read per evaluation. For scale, consider Custom Auth Claims.
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function getUserName() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name;
    }

    function isSuperAdmin() {
      return getUserRole() in ["super_admin", "admin", "Super Admin"];
    }

    function isTLOrSupport() {
      return getUserRole() in ["tl", "support", "Team Leader", "Quality Assurance", "QA"];
    }

    // Agent can only update if they are the author or assigned
    function isOwnerOrAssigned() {
      let userName = getUserName();
      return resource.data.agentName == userName || 
             resource.data.assignedToName == userName ||
             resource.data.openedBy == userName ||
             resource.data.submittedByName == userName;
    }

    // Users
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
    }

    // Cases, Requests, Inquiries
    match /inquiries/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isTLOrSupport() || isSuperAdmin() || isOwnerOrAssigned());
    }
    match /tt_requests/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isTLOrSupport() || isSuperAdmin() || isOwnerOrAssigned());
    }
    match /tt_complaints/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isTLOrSupport() || isSuperAdmin() || isOwnerOrAssigned());
    }
    match /client_comms/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isTLOrSupport() || isSuperAdmin() || isOwnerOrAssigned());
    }
    match /scheduling_requests/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isTLOrSupport() || isSuperAdmin() || isOwnerOrAssigned());
    }
    match /cases/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isTLOrSupport() || isSuperAdmin() || isOwnerOrAssigned());
    }
    match /case_activity/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      // Immutable log
      allow update, delete: if false;
    }

    // Timelogs - only superadmin/admin can purge 
    match /timelogs/{logId} {
      allow read, create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.agentName == getUserName() || isSuperAdmin() || isTLOrSupport());
      allow delete: if isSignedIn() && isSuperAdmin();
    }

    // Notifications - users may only mark their own notification read/cleared state
    match /notifications/{notifId} {
      // Allow read/create for system
      allow read, create: if isSignedIn();
      // Restrict update/delete
      // Cannot fully restrict based strictly on UID since the app uses `targetAgentName` or `targetRole`. 
      // To prevent breaking, allow update if user name matches target, or if TL/Admin.
      allow update, delete: if isSignedIn() && 
        (resource.data.targetAgentName == getUserName() || 
         resource.data.targetRole == getUserRole() || 
         isSuperAdmin() || isTLOrSupport() ||
         resource.data.targetRole == 'general');
    }

    // Others (Basic fallback for existing functionality)
    match /todos/{todoId} { allow read, write: if isSignedIn(); }
    match /qa_scores/{scoreId} { allow read, write: if isSignedIn(); }
    match /system/{docId} { allow read, write: if isSignedIn(); }
    match /announcements/{annId} { allow read: if isSignedIn(); allow write: if isSignedIn() && isSuperAdmin(); }
    match /tl_feedbacks/{fbId} { allow read, write: if isSignedIn(); }
    match /schedules/{schedId} { allow read, write: if isSignedIn(); }
    match /orders/{orderId} { allow read, write: if isSignedIn(); }
    match /agents/{agentId} { allow read, write: if isSignedIn(); }
    match /agents/{agentId}/schedules/{schedId} { allow read, write: if isSignedIn(); }
  }
}
