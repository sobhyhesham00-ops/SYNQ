rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() { return request.auth != null; }

    function getUserData() {
      // Fetch user path. Because we DO NOT use isSuperAdmin() or getUserRole() in the 'read'
      // rule of the 'users' collection, this get() call does not trigger a circular evaluation.
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function getUserName() {
      let data = getUserData();
      return data != null ? data.name : null;
    }

    function getUserRole() {
      let data = getUserData();
      return data != null ? data.role : null;
    }

    function isSuperAdmin() {
      let role = getUserRole();
      return role == 'tl' || role == 'admin' || role == 'superadmin';
    }

    function isTLOrSupport() {
      let role = getUserRole();
      return role == 'tl';
    }

    function isRecipientOf(notifData) {
      let uid = request.auth.uid;
      let role = getUserRole();
      let name = getUserName();
      return notifData.targetAgent == uid ||
             notifData.targetAgent == "all" ||
             notifData.targetAgent == role ||
             (notifData.targetGroups != null && notifData.targetGroups.hasAny([uid, "usr_" + uid, "all", role, name, name.toLowerCase()]));
    }

    // Users Collection
    // Read: Simple authentication check with no nested helper calls. This completely eliminates the 
    // circular evaluation risk since role-lookup functions (like getUserRole) fetch from this collection.
    // Write: Allow authenticated users to create/update their own profile, but prevent self-escalation of 'role'.
    // Administrators/TLs can also modify profiles.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        (request.auth.uid == userId && (
          !request.resource.data.keys().hasAny(['role']) || 
          request.resource.data.role == resource.data.role
        )) || 
        // Break cycle: we fetch role directly instead of via the helper to avoid rules engine 
        // caching/cycle detection bugs, though the read rule fix is the primary non-cycle guarantee.
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['tl', 'admin', 'superadmin'])
      );
      allow delete: if request.auth != null && (
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['tl', 'admin', 'superadmin'])
      );
    }

    // Cases, Requests, Inquiries
    match /inquiries/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isTLOrSupport() || isSuperAdmin() || resource.data.agentName == getUserName() || resource.data.userId == request.auth.uid);
    }
    match /tabby_tamara/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isTLOrSupport() || isSuperAdmin() || resource.data.agentName == getUserName() || resource.data.agentId == request.auth.uid);
    }
    match /tabby_tamara_complaints/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isTLOrSupport() || isSuperAdmin() || resource.data.agentName == getUserName() || resource.data.agentId == request.auth.uid);
    }
    match /client_comms/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isTLOrSupport() || isSuperAdmin() || resource.data.agentName == getUserName() || resource.data.callCenterAgentName == getUserName());
    }
    match /scheduling_requests/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isTLOrSupport() || isSuperAdmin() || resource.data.agentName == getUserName() || resource.data.userId == request.auth.uid);
    }
    match /cases/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isTLOrSupport() || isSuperAdmin() || resource.data.agentName == getUserName() || resource.data.userId == request.auth.uid);
    }
    match /case_activity/{docId} {
      allow read, create: if isSignedIn();
      allow update, delete: if false;
    }

    // Timelogs
    match /timelogs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isTLOrSupport() || isSuperAdmin() || resource.data.agentName == getUserName() || resource.data.userId == request.auth.uid);
    }

    // Notifications
    match /notifications/{notifId} {
      allow read, create: if isSignedIn();
      allow update: if isSignedIn() && (
        isSuperAdmin() || 
        isTLOrSupport() ||
        resource.data.targetAgent == getUserName() ||
        resource.data.targetAgent == "all" ||
        resource.data.targetAgent == getUserRole() ||
        (resource.data.targetGroups != null && getUserName() in resource.data.targetGroups) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['seenByUsers', 'clearedByUsers'])
      );
      allow delete: if isSignedIn() && (isSuperAdmin() || isTLOrSupport());
    }

    // Others
    match /todos/{todoId} { 
      allow read, create: if isSignedIn(); 
      allow update, delete: if isSignedIn() && (isSuperAdmin() || isTLOrSupport() || resource.data.agentName == getUserName() || resource.data.userId == request.auth.uid || request.resource.data.agentName == getUserName());
    }
    match /qa_scores/{scoreId} { 
      allow read, create: if isSignedIn(); 
      allow update, delete: if isSignedIn() && (isSuperAdmin() || isTLOrSupport() || getUserRole() == 'qa');
    }
    match /system/{docId} { 
      allow read: if isSignedIn(); 
      allow write: if isSignedIn() && isSuperAdmin(); 
    }
    match /system/sched_agent_directory {
      allow read: if request.auth != null;  // allow all reads from cache
      allow write: if request.auth != null;  // require any auth (anon or real user)
    }
    match /system/sched_agent_directory_headers {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /announcements/{annId} { 
      allow read: if isSignedIn(); 
      allow write: if isSignedIn() && (isSuperAdmin() || isTLOrSupport()); 
    }
    match /tl_feedbacks/{fbId} { 
      allow read, create: if isSignedIn(); 
      allow update, delete: if isSignedIn() && (isSuperAdmin() || isTLOrSupport() || resource.data.agentName == getUserName());
    }
    match /schedules/{schedId} { 
      allow read: if isSignedIn(); 
      allow write: if isSignedIn() && (isSuperAdmin() || isTLOrSupport()); 
    }
    match /orders/{orderId} { 
      allow read, create: if isSignedIn(); 
      allow update, delete: if isSignedIn() && (isSuperAdmin() || isTLOrSupport() || resource.data.agentName == getUserName());
    }
    match /agents/{agentId} { 
      allow read: if isSignedIn(); 
      allow write: if isSignedIn() && (isSuperAdmin() || isTLOrSupport()); 
    }
    match /agents/{agentId}/schedules/{schedId} { 
      allow read: if isSignedIn(); 
      allow write: if isSignedIn() && (isSuperAdmin() || isTLOrSupport()); 
    }

    // Messages
    match /messages/{msgId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow delete: if isSignedIn() && request.auth.uid in resource.data.participants;
    }

    // Articles
    match /articles/{articleId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && (
        isSuperAdmin() || isTLOrSupport() ||
        getUserRole() == 'qa'
      );
    }
  }
}
