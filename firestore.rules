rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() { return request.auth != null; }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getUserName() {
      return getUserData().name;
    }

    function getUserRole() {
      return getUserData().role;
    }

    function isSuperAdmin() {
      return getUserRole() == 'tl' || getUserRole() == 'admin' || getUserRole() == 'superadmin';
    }

    function isTLOrSupport() {
      return getUserRole() == 'tl';
    }

    function isRecipientOf(notifData) {
      let uid = request.auth.uid;
      let role = getUserRole();
      let name = getUserName();
      return notifData.targetAgent == uid ||
             notifData.targetAgent == "all" ||
             notifData.targetAgent == role ||
             (notifData.targetGroups != null && notifData.targetGroups.hasAny([uid, "usr_" + uid, "all", role, name, name.toLowerCase()]));
    }

    // Users
    match /users/{userId} {
      allow read, write: if isSignedIn();
    }

    // Cases, Requests, Inquiries
    match /inquiries/{docId} {
      allow read, write: if isSignedIn();
    }
    match /tt_requests/{docId} {
      allow read, write: if isSignedIn();
    }
    match /tt_complaints/{docId} {
      allow read, write: if isSignedIn();
    }
    match /client_comms/{docId} {
      allow read, write: if isSignedIn();
    }
    match /scheduling_requests/{docId} {
      allow read, write: if isSignedIn();
    }
    match /cases/{docId} {
      allow read, write: if isSignedIn();
    }
    match /case_activity/{docId} {
      allow read, create: if isSignedIn();
      allow update, delete: if false;
    }

    // Timelogs
    match /timelogs/{logId} {
      allow read, write: if isSignedIn();
    }

    // Notifications
    match /notifications/{notifId} {
      allow read, create: if isSignedIn();
      allow update: if isSignedIn() && (
        isSuperAdmin() || 
        isTLOrSupport() ||
        resource.data.targetAgent == getUserName() ||
        resource.data.targetAgent == "all" ||
        resource.data.targetAgent == getUserRole() ||
        (resource.data.targetGroups != null && getUserName() in resource.data.targetGroups) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['seenByUsers', 'clearedByUsers'])
      );
      allow delete: if isSignedIn() && (isSuperAdmin() || isTLOrSupport());
    }

    // Others (Basic fallback for existing functionality)
    match /todos/{todoId} { allow read, write: if isSignedIn(); }
    match /qa_scores/{scoreId} { allow read, write: if isSignedIn(); }
    match /system/{docId} { allow read, write: if isSignedIn(); }
    match /system/sched_agent_directory {
      allow read: if request.auth != null || request.auth == null;  // allow all reads from cache
      allow write: if request.auth != null;  // require any auth (anon or real user)
    }
    match /system/sched_agent_directory_headers {
      allow read: if request.auth != null || request.auth == null;
      allow write: if request.auth != null;
    }
    match /announcements/{annId} { allow read, write: if isSignedIn(); }
    match /tl_feedbacks/{fbId} { allow read, write: if isSignedIn(); }
    match /schedules/{schedId} { allow read, write: if isSignedIn(); }
    match /orders/{orderId} { allow read, write: if isSignedIn(); }
    match /agents/{agentId} { allow read, write: if isSignedIn(); }
    match /agents/{agentId}/schedules/{schedId} { allow read, write: if isSignedIn(); }
  }
}
