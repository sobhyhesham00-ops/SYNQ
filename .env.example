# ==========================================
# Core Application Configuration
# ==========================================

# NODE_ENV: Specifies the environment the application is running in.
# For local development, this should be "development". For live deployments, use "production".
NODE_ENV=development

# PORT: The port the development server and Express backend (if applicable) binds to.
# This MUST be set to 3000 to be compatible with standard container setups.
PORT=3000

# APP_URL: The base URL of the application.
# Used for constructing absolute URLs, webhooks, or OAuth callbacks.
APP_URL=http://localhost:3000

# ==========================================
# Secret Keys & APIs
# ==========================================

# GEMINI_API_KEY: Authentication key for Google's Gemini AI SDK / Google AI Studio.
# Securely obtain this from the Google AI Studio dashboard. Do NOT commit this to version control.
GEMINI_API_KEY=your_gemini_api_key_here

# ==========================================
# Firebase Configuration
# ==========================================
# These variables configure the Firebase SDKs.
# You can find these in your Firebase Console under Project Settings -> General.
# Note: For Vite (React) client-side usage, prefix variables with "VITE_" if you want them accessible in the browser.

# FIREBASE_PROJECT_ID: The unique identifier for your Firebase project.
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PROJECT_ID=your_firebase_project_id

# FIREBASE_API_KEY: The Web API Key used for Firebase services and Authentication.
VITE_FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_API_KEY=your_firebase_api_key

# FIREBASE_AUTH_DOMAIN: The authorization domain for Firebase Auth (usually your_project_id.firebaseapp.com).
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com

# Additional Firebase Variables
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

