{
  "name": "team-scheduling-portal-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "dev:emulator": "concurrently -k -n \"emulator,dev\" -c \"yellow,blue\" \"firebase emulators:start --only auth,firestore\" \"VITE_USE_EMULATOR=true npm run dev\"",
    "build": "vite build",
    "start": "node server.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "vitest run --project=e2e",
    "lint": "tsc"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.4.0",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "dotenv": "^17.2.3",
    "esbuild": "^0.25.12",
    "express": "^4.21.2",
    "firebase": "^12.13.0",
    "lucide-react": "^0.546.0",
    "mammoth": "^1.12.0",
    "motion": "^12.40.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vite-plugin-pwa": "^1.3.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.19.20",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.0",
    "firebase-tools": "^15.19.1",
    "jsdom": "^29.1.1",
    "puppeteer": "^25.1.0",
    "vitest": "^4.1.8"
  }
}
